# transfero-on-ramp environment variables
# Copy to .env and fill in real values.

# Port this service listens on
ONRAMP_PORT=8094

# Own PostgreSQL database (stores quotes and orders)
ONRAMP_DB_URL=postgres://user:pass@localhost:5432/onramp?sslmode=disable

# Dinapay PostgreSQL database — used to resolve customer API keys to account IDs.
# Leave empty to fall back to the static ONRAMP_API_KEYS list.
DINAPAY_DB_URL=postgres://user:pass@localhost:5432/dinapay?sslmode=disable

# DinaCore balance API
DINACORE_URL=http://localhost:8093
DINACORE_API_KEY=your-dinacore-api-key

# Transfero OTC API
# Staging: https://staging.otc.transfero.com
# Production: https://otc.transfero.com
TRANSFERO_API_URL=https://staging.otc.transfero.com
TRANSFERO_API_KEY=your-transfero-api-key

# Comma-separated static API keys (fallback when DINAPAY_DB_URL is not set)
ONRAMP_API_KEYS=key1,key2
